# Supabase Credentials
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Admin reset token
ADMIN_RESET_TOKEN=change-with-secure-token

# Payment mode: "simulasi" or "midtrans"
NEXT_PUBLIC_PAYMENT_MODE=simulasi

# Midtrans Configuration
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# Rate limiting (optional)
# Without the Upstash vars below the limiter falls back to in-memory mode,
# which only protects within a single server instance. Set both to share the
# limit across all instances (recommended for serverless / multi-instance).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Max requests per window per IP (default 10) and window length in seconds (default 10).
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECONDS=10
