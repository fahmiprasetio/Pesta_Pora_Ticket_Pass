# Kredensial Supabase (Dashboard -> Project Settings -> API)
# Salin file ini menjadi .env.local lalu isi nilainya.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Token untuk panel admin reset stok demo (/admin). Bebas, mis. string acak.
# Kosongkan untuk menonaktifkan endpoint reset.
ADMIN_RESET_TOKEN=ganti-dengan-token-rahasia

# Pembayaran: "simulasi" (default, dipakai load test) atau "midtrans".
NEXT_PUBLIC_PAYMENT_MODE=simulasi

# Midtrans (Dashboard Midtrans -> Settings -> Access Keys). Pakai key Sandbox.
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
# Set "true" hanya untuk mode produksi Midtrans. Default sandbox.
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false
